{
  "name": "@cra-ready/cli",
  "version": "0.1.0",
  "description": "Push SBOMs to CRA Ready from your terminal or CI.",
  "license": "MIT",
  "author": "CRA Ready",
  "homepage": "https://github.com/cra-ready/cli#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/cra-ready/cli.git"
  },
  "bugs": {
    "url": "https://github.com/cra-ready/cli/issues"
  },
  "keywords": [
    "sbom",
    "cra",
    "cyber-resilience-act",
    "cli",
    "cyclonedx",
    "supply-chain",
    "security"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cra-ready": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.0.0",
    "commander": "^13.0.0",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.4.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.0"
  }
}
