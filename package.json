    "lint": "eslint src",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.0.0",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
