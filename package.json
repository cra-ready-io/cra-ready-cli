{
  "name": "@cra-ready/cli",
  "version": "0.1.0",
  "description": "Push SBOMs to CRA Ready from your terminal or CI.",
  "license": "MIT",
  "homepage": "https://github.com/cra-ready/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/cra-ready/cli.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cra-ready": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
